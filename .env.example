TELEGRAM_TOKEN=123456:replace_me
ALLOWED_USER_ID=123456789
# 多用户可以用：
# ALLOWED_USER_IDS=123456789,987654321

# 飞牛上保存 docker-compose.yml 的目录，按你的实际路径改。
DOCKER_COMPOSE_DIR=/vol1/1000/docker-services

# 如果 compose 文件不是默认文件名，可以指定：
# DOCKER_COMPOSE_FILE=/vol1/1000/docker-services/docker-compose.yml

COMMAND_TIMEOUT=120
LOG_TAIL=80

# 飞牛无法直连 Telegram 时配置代理。
# HTTP 示例：TELEGRAM_PROXY_URL=http://192.168.1.2:7890
# SOCKS5 示例：TELEGRAM_PROXY_URL=socks5://192.168.1.2:7891
# TELEGRAM_PROXY_URL=
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_READ_TIMEOUT=30
