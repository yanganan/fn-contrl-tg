TELEGRAM_TOKEN=123456:replace_me
ALLOWED_USER_ID=123456789
# 多用户可以用：
# ALLOWED_USER_IDS=123456789,987654321

# 飞牛上保存 docker-compose.yml 的目录，按你的实际路径改。
DOCKER_COMPOSE_DIR=/vol1/1000/docker-services

# 如果 compose 文件不是默认文件名，可以指定：
# DOCKER_COMPOSE_FILE=/vol1/1000/docker-services/docker-compose.yml

COMMAND_TIMEOUT=120
LOG_TAIL=80
LOG_LEVEL=INFO

# ─── Phase 2: 异步化 + 监控 (#10-#13) ──────────────────────
# Docker 事件监听：容器异常退出/OOM/健康检查失败时告警
ENABLE_EVENT_MONITOR=true
# 忽略告警的容器名（逗号分隔）
EVENT_IGNORE=watchtower,cadvisor

# 资源阈值监控
ENABLE_RESOURCE_MONITOR=true
DISK_THRESHOLD=85
MEM_THRESHOLD=90
CPU_THRESHOLD=95
RESOURCE_CHECK_INTERVAL=60
# 同一告警的冷却期（秒），避免重复刷屏
ALERT_COOLDOWN=1800

# ─── Phase 3: 核心新功能 (#14-#17) ──────────────────────────
# 定时镜像更新检查（单位：小时，默认 6 小时检查一次）
ENABLE_UPDATE_CHECKER=true
UPDATE_CHECK_INTERVAL=6
# 忽略检查的服务名（逗号分隔）
UPDATE_IGNORE=watchtower,cadvisor

# 多 Compose 项目支持（冒号分隔多个目录）
# 不设置则使用 DOCKER_COMPOSE_DIR
# COMPOSE_DIRS=/vol1/1000/docker-services:/opt/media-stack:/opt/home-auto

# 操作历史数据库路径（需要持久化卷映射）
HISTORY_DB=/data/bot_history.db

# 飞牛无法直连 Telegram 时配置代理。
# HTTP 示例：TELEGRAM_PROXY_URL=http://192.168.1.2:7890
# SOCKS5 示例：TELEGRAM_PROXY_URL=socks5://192.168.1.2:7891
# TELEGRAM_PROXY_URL=
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_READ_TIMEOUT=30
